# ── Backend ──────────────────────────────────────────────────────────────
# The backend loads its vars from `backend/.env` (env_file is CWD-relative and
# uvicorn/Docker run from the backend dir). Copy this block to `backend/.env`.

# Local Docker Postgres (default, local-first):
DATABASE_URL=postgresql+asyncpg://pam:pam@localhost:5432/pam

# Neon (or any managed Postgres) as a DEV DB — note the asyncpg quirks:
#   * use the DIRECT (non-pooled) endpoint — drop the `-pooler` suffix
#     (pgbouncer + asyncpg break prepared statements)
#   * asyncpg wants `?ssl=require`, NOT libpq's `sslmode=require`
#   * driver prefix must be `postgresql+asyncpg://`
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/dbname?ssl=require

CORS_ORIGINS=chrome-extension://*,http://localhost:3000
LOG_LEVEL=INFO

# ── Phase 2: embeddings (local Ollama) ────────────────────────────────────
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# ── Phase 4: chat LLM ─────────────────────────────────────────────────────
# Provider: "groq" (cloud, free, default) or "ollama" (local chat model).
LLM_PROVIDER=groq
# Free key from https://console.groq.com → API Keys (no card). Keep it secret.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_CHAT_MODEL=llama3.2:3b

# ── Web UI ───────────────────────────────────────────────────────────────
# Optional override of the backend URL (defaults to http://localhost:8000).
# Set in your shell or web/.env.local.
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
